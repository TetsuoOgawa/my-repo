root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_style = space
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all

[*.{csproj,sln,config,xml}]
indent_size = 2
end_of_line = lf

[*.{json,yml,yaml}]
indent_size = 2
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
end_of_line = lf